# This is an example .env file for the Kotatsu Sync Server.
# Copy this file to .env and replace the values with your actual configuration.
#
# IMPORTANT: For docker-compose, this .env file is automatically loaded.
#            Just copy this file to .env and update the values below.

# ==============================================================================
# Database Configuration
# ==============================================================================
# Database server hostname (default: localhost)
# For docker-compose, this is automatically set to 'mysql' (the service name)
DATABASE_HOST=localhost

# Database server port (default: 3306)
DATABASE_PORT=3306

# Database name (default: kotatsu_db)
DATABASE_NAME=kotatsu_db

# Database username (required)
DATABASE_USER=kotatsu

# Database password (required)
# CHANGE THIS to a secure password in production!
DATABASE_PASSWORD=change_me_secure_password

# Database root password (optional)
# If set, the application will automatically create the database and user on first run.
# Useful for Docker Compose deployments. Leave empty if database is manually created.
# CHANGE THIS to a secure password in production!
DATABASE_ROOT_PASSWORD=change_me_root_password

# ==============================================================================
# JWT Configuration
# ==============================================================================
# HMAC256 secret for JWT signing (required)
# CHANGE THIS to a long random string (e.g., openssl rand -base64 32) for security!
JWT_SECRET=change_me_use_openssl_rand_base64_32

# JWT issuer claim (default: http://0.0.0.0:9292/)
JWT_ISSUER=http://0.0.0.0:9292/

# JWT audience claim (default: http://0.0.0.0:9292/resource)
JWT_AUDIENCE=http://0.0.0.0:9292/resource

# ==============================================================================
# Server Configuration
# ==============================================================================
# HTTP port the server will listen on (default: 9292)
PORT=9292

# ==============================================================================
# Application Configuration
# ==============================================================================
# Enable/disable new user registration (true/false, default: true)
ALLOW_NEW_REGISTER=true

# Base URL for deep links and emails (default: http://localhost:9292)
BASE_URL=http://localhost:9292

# ==============================================================================
# Mail Configuration
# ==============================================================================
# Mail provider: "console" (logs to console) or "smtp" (default: console)
MAIL_PROVIDER=console

# SMTP server hostname (required when MAIL_PROVIDER=smtp)
SMTP_HOST=

# SMTP server port (default: 587)
SMTP_PORT=587

# SMTP authentication username
SMTP_USERNAME=

# SMTP authentication password
SMTP_PASSWORD=

# From email address for outgoing mail (required when MAIL_PROVIDER=smtp)
SMTP_FROM=

# ==============================================================================
# Logger Configuration
# ==============================================================================
# Possible values for LOG_LEVEL: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Log format: text (human-readable with colors) or json (structured) (default: text)
LOG_FORMAT=text

# Enable/disable logging outputs (default: true for all)
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true
ENABLE_ACCESS_FILE_LOGGING=true

# Directory for log files (relative or absolute path) (default: logs)
LOG_DIRECTORY=logs

# Maximum size per log file (e.g., 20m = 20 megabytes) (default: 20m)
LOG_MAX_FILE_SIZE=20m

# Maximum number of backup log files to keep (default: 14)
LOG_MAX_FILES=14
