# Docker Compose .env example
# This file is specifically for docker-compose deployments.
# Copy this file to .env when using docker-compose.yml
#
# SECURITY WARNING: Change all passwords and secrets before deploying!

# ==============================================================================
# Database Configuration (Docker Compose)
# ==============================================================================
# DATABASE_HOST is automatically set to 'mysql' in docker-compose.yml
# Don't set it here - it's overridden for container networking

# Database server port
DATABASE_PORT=3306

# Database name
DATABASE_NAME=kotatsu_db

# Database username
DATABASE_USER=kotatsu

# Database password
# ⚠️  CHANGE THIS in production!
DATABASE_PASSWORD=change_me_secure_password

# Database root password (enables auto-initialization)
# ⚠️  CHANGE THIS in production!
DATABASE_ROOT_PASSWORD=change_me_root_password

# ==============================================================================
# JWT Configuration
# ==============================================================================
# HMAC256 secret for JWT signing
# ⚠️  REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=change_me_use_openssl_rand_base64_32

# JWT issuer claim (optional)
JWT_ISSUER=http://0.0.0.0:9292/

# JWT audience claim (optional)
JWT_AUDIENCE=http://0.0.0.0:9292/resource

# ==============================================================================
# Server Configuration
# ==============================================================================
# HTTP port the server will listen on
PORT=9292

# ==============================================================================
# Application Configuration
# ==============================================================================
# Enable/disable new user registration
ALLOW_NEW_REGISTER=true

# Base URL for deep links and emails
# Update this to your production domain
BASE_URL=http://localhost:9292

# ==============================================================================
# Mail Configuration
# ==============================================================================
# Mail provider: "console" (logs to console) or "smtp"
MAIL_PROVIDER=console

# SMTP Configuration (only needed if MAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_username
# SMTP_PASSWORD=your_password
# SMTP_FROM=noreply@example.com

# ==============================================================================
# Logger Configuration
# ==============================================================================
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Log format: text (human-readable) or json (structured)
# Use json for production/container logs
LOG_FORMAT=json

# Enable/disable logging outputs
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true
ENABLE_ACCESS_FILE_LOGGING=true

# Directory for log files
LOG_DIRECTORY=logs

# Maximum size per log file (e.g., 20m = 20 megabytes)
LOG_MAX_FILE_SIZE=20m

# Maximum number of backup log files to keep
LOG_MAX_FILES=14
